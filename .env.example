NEXT_PUBLIC_API_URL=http://localhost:3000

# Your public site URL (no trailing slash), e.g. https://scigestible.com.
# Used for the sitemap, robots.txt, and canonical/Open Graph URLs.
# On Vercel this falls back to the production deployment URL if unset.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
OPENAI_API_KEY=your_openai_api_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: contact email for the OpenAlex & Crossref "polite pool" (faster, more reliable paper search). No signup needed.
PAPER_SEARCH_CONTACT_EMAIL=you@example.com

# Optional: CORE API key for 270M+ open-access full texts in paper search. Free key at https://core.ac.uk/services/api
CORE_API_KEY=your_core_api_key_here

# Optional: Google AdSense publisher ID (ca-pub-...). When set, free users see display ads; Pro users never do.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
